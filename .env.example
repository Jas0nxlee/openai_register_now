# 可选：代理
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"

# ===== 邮箱配置（必填）=====
# 你在 Cloudflare 托管的域名（Email Routing 配好后，邮件会触发 Worker）
# 如果指定了 CF_EMAIL_ADDRESS 则忽略 CF_EMAIL_DOMAIN 和 CF_EMAIL_PREFIX
CF_EMAIL_DOMAIN="example.com"
# CF_EMAIL_ADDRESS="alice@example.com"   # 固定邮箱地址（可选）
# CF_EMAIL_PREFIX="alice"                # 固定前缀（可选，不填则随机生成）

# ===== Cloudflare Worker 配置（必填）=====
# Worker 的 URL（部署后从 Cloudflare Dashboard 或 wrangler deploy 输出中获取）
CF_WORKER_URL="https://otpstore.your-username.workers.dev"
# 与 wrangler secret put WORKER_API_KEY 设置的值一致
CF_WORKER_API_KEY="your-random-secret-key-here"
